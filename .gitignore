# ═══════════════════════════════════════════════════
#  ROMANOV — .gitignore
#  Electron app  ·  macOS + Windows
# ═══════════════════════════════════════════════════

# ── Node / npm ───────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml
.npmrc

# ── Electron build output ────────────────────────
dist/
out/
build/
release/
*.dmg
*.exe
*.msi
*.AppImage
*.deb
*.rpm
*.snap
*.nupkg
*.blockmap

# ── Electron Forge / Builder cache ───────────────
.webpack/
.vite/

# ── Environment & secrets ────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
*.p12
*.pfx

# ── macOS ────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Icon?
Thumbs.db

# ── Windows ──────────────────────────────────────
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
*.stackdump

# ── IDE & editor ─────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
.vs/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# ── Logs & runtime ───────────────────────────────
logs/
*.log
pids/
*.pid
*.seed

# ── Coverage & test output ───────────────────────
coverage/
.nyc_output/
*.lcov
test-results/

# ── Temp & cache ─────────────────────────────────
.cache/
.temp/
tmp/
*.tmp

# Environments
.env
.venv
venv/
ENV/
env/
venv.bak/

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# SQLite Database
*.db
*.sqlite
*.sqlite3

# Distribution / packaging
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Kokoro voice models
kokoro-v0_19.onnx
voices.json
voices.bin
restart_trigger.txt
