# ═══════════════════════════════════════════════════
#  ROMANOV — .gitignore
#  Electron app  ·  macOS + Windows
# ═══════════════════════════════════════════════════

# ── Node / npm ───────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json
yarn.lock
pnpm-lock.yaml
.npmrc

# ── Electron build output ────────────────────────
dist/
out/
build/
release/
*.dmg
*.exe
*.msi
*.AppImage
*.deb
*.rpm
*.snap
*.nupkg
*.blockmap

# ── Electron Forge / Builder cache ───────────────
.webpack/
.vite/

# ── Environment & secrets ────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
*.p12
*.pfx

# ── macOS ────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
Icon?
Thumbs.db

# ── Windows ──────────────────────────────────────
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk
*.stackdump

# ── IDE & editor ─────────────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo
*~

# ── Logs & runtime ───────────────────────────────
logs/
*.log
pids/
*.pid
*.seed

# ── Coverage & test output ───────────────────────
coverage/
.nyc_output/
*.lcov
test-results/

# ── Temp & cache ─────────────────────────────────
.cache/
.temp/
tmp/
*.tmp
