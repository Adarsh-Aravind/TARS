# LLM provider selection (must match config.py field names)
LLM_PROVIDER=groq            # groq, ollama, openai, gemini
LLM_MODEL=llama-3.3-70b-versatile
TEMPERATURE=0.1

# Groq (free tier). Get a key at https://console.groq.com/keys
# Models with reliable tool calling:
#   llama-3.3-70b-versatile   <- default, best all-round
#   llama-3.1-8b-instant      <- fastest, use if latency matters more than smarts
#   moonshotai/kimi-k2-instruct
GROQ_API_KEY=your_groq_api_key_here

# Where this backend reaches Ollama.
#   - Host PC (the machine actually running Ollama): keep localhost.
#   - A friend's machine sharing the host's Ollama: point this at the host's
#     Tailscale IP, e.g. OLLAMA_BASE_URL=http://100.x.y.z:11434
#     (The host must start Ollama with OLLAMA_HOST=0.0.0.0 so it accepts
#      connections from the Tailscale interface — see README > Shared Ollama.)
OLLAMA_BASE_URL=http://localhost:11434

# Cloud provider keys (only needed if LLM_PROVIDER is openai or gemini)
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

MAX_TOKENS=1024
RATE_LIMIT_RPM=60
SQLITE_PATH=./tars.db
WHISPER_MODEL=tiny.en        # tiny.en, tiny, base, small, medium, large-v3
