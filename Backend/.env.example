# LLM provider selection (must match config.py field names)
LLM_PROVIDER=ollama          # ollama, openai, gemini
LLM_MODEL=qwen2.5:7b
TEMPERATURE=0.1
OLLAMA_BASE_URL=http://localhost:11434

# Cloud provider keys (only needed if LLM_PROVIDER is openai or gemini)
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

MAX_TOKENS=1024
RATE_LIMIT_RPM=60
SQLITE_PATH=./tars.db
WHISPER_MODEL=tiny.en        # tiny.en, tiny, base, small, medium, large-v3
